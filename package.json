{
  "name": "feathersjs-mcp",
  "version": "1.0.4",
  "description": "MCP server that gives AI assistants access to the FeathersJS v6 documentation",
  "homepage": "https://feathersjs.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/nazifishrak/FeathersMCP.git"
  },
  "keywords": [
    "mcp",
    "modelcontextprotocol",
    "feathers-plugin",
    "feathers",
    "ai",
    "cursor",
    "vscode",
    "claude"
  ],
  "license": "MIT",
  "contributors": [],
  "type": "module",
  "bin": {
    "feathersjs-mcp": "./build/index.js"
  },
  "scripts": {
    "build": "tsc && chmod 755 build/index.js",
    "ingest": "tsx src/scripts/ingest.ts",
    "test:search": "tsx src/tests/test-search.ts",
    "test:pipeline": "tsx src/tests/full-pipeline-test.ts",
    "test:mcp": "tsx src/tests/test-mcp-protocol.ts",
    "test:css": "tsx src/tests/verify-css-fix.ts",
    "start": "node build/index.js"
  },
  "files": [
    "build",
    "data",
    "README.md"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@octokit/rest": "^22.0.1",
    "better-sqlite3": "^12.6.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.2.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
